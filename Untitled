#include "Movie.h"

using namespace std;

// Constructor implicit
Movie::Movie() : Content() {
    duration = 0;
}

// Constructor cu parametri
Movie::Movie(const string& title, const string& genre, int year, double rating, int duration)
    : Content(title, genre, year, rating) {
    this->duration = duration;
}

// Copy constructor
Movie::Movie(const Movie& other) : Content(other) {
    duration = other.duration;
}

// Operator =
Movie& Movie::operator=(const Movie& other) {
    if (this != &other) {
        Content::operator=(other);
        duration = other.duration;
    }
    return *this;
}

// Destructor
Movie::~Movie() {
}